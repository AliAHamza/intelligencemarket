    }
    @model List<RecommendationApp.Models.CartItem>
        @{
            ViewData["Title"] = "Shopping Cart";
            ViewData["ActivePage"] = "Cart";
            var total = Model.Sum(c => c.Price * c.Quantity);
        }

        @section Styles {
            <style>
                .cart-layout {
                    display: grid;
                    grid-template-columns: 1fr;
                    gap: 1.2rem;
                    align-items: start;
                }

                @@media(min-width:900px) {
                    .cart-layout {
                        grid-template-columns: 1fr 340px;
                        gap: 1.5rem;
                    }
                }

                .cart-item {
                    display: flex;
                    align-items: center;
                    gap: .9rem;
                    padding: .9rem;
                    background: var(--surface2);
                    border: 1px solid var(--border);
                    border-radius: 14px;
                    margin-bottom: .7rem;
                    transition: border-color .2s;
                }

                    .cart-item:hover {
                        border-color: rgba(0,212,255,.2);
                    }

                .cart-icon-box {
                    width: 56px;
                    height: 56px;
                    border-radius: 12px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 1.8rem;
                    flex-shrink: 0;
                    border: 1px solid var(--border);
                }

                .cart-item-info {
                    flex: 1;
                    min-width: 0;
                }

                .cart-item-name {
                    font-weight: 700;
                    margin-bottom: 3px;
                    font-size: .92rem;
                }

                .cart-item-price {
                    color: var(--accent3);
                    font-weight: 900;
                    font-size: .9rem;
                }

                .cart-item-qty {
                    color: var(--text-muted);
                    font-size: .78rem;
                }

                .cart-item-total {
                    font-size: 1.05rem;
                    font-weight: 900;
                    color: var(--accent);
                    white-space: nowrap;
                    flex-shrink: 0;
                }

                .summary-card {
                    background: var(--surface);
                    border: 1px solid var(--border);
                    border-radius: 16px;
                    padding: 1.4rem;
                }

                @@media(min-width:900px) {
                    .summary-card {
                        position: sticky;
                        top: 80px;
                    }
                }

                .summary-row {
                    display: flex;
                    justify-content: space-between;
                    padding: 9px 0;
                    border-bottom: 1px solid var(--border);
                    font-size: .9rem;
                    gap: 1rem;
                }

                    .summary-row:last-of-type {
                        border-bottom: none;
                    }

                .summary-total {
                    font-size: 1.15rem;
                    font-weight: 900;
                    color: var(--accent);
                }

                .empty-cart {
                    text-align: center;
                    padding: 4rem 2rem;
                    color: var(--text-muted);
                }

                .empty-icon {
                    font-size: 4rem;
                    display: block;
                    margin-bottom: 1rem;
                }
            </style>
        }

        <div class="section-header">
            <i class="fas fa-shopping-cart" style="color:var(--accent)"></i>
            <h2>Shopping Cart</h2>
            <span class="section-badge">@Model.Count item@(Model.Count == 1 ? "" : "s")</span>
            <div class="divider"></div>
        </div>

        @if (!Model.Any())
        {
            <div class="card">
                <div class="empty-cart">
                    <span class="empty-icon">🛒</span>

                    <h3 style="margin-bottom:.5rem;">Your cart is empty!</h3>

                    <p style="margin-bottom:1.5rem;">
                        Add products from recommendations or browse the store.
                    </p>

                    <a href="/Home/Index" class="btn btn-primary" style="text-decoration:none;margin-right:8px;">
                        <i class="fas fa-star"></i> Recommendations
                    </a>

                    <a href="/Home/Products" class="btn btn-secondary" style="text-decoration:none;">
                        <i class="fas fa-store"></i> Store
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="cart-layout">
                <div>
                    @foreach (var item in Model)
                    {
                        <div class="cart-item">
                            <div class="cart-icon-box" style="background:var(--surface);">
                                @item.CategoryIcon
                            </div>

                            <div class="cart-item-info">
                                <div class="cart-item-name">@item.ProductName</div>
                                <div class="cart-item-price">@item.Price.ToString("F2") $</div>
                                <div class="cart-item-qty">Quantity: @item.Quantity</div>
                            </div>

                            <div class="cart-item-total">
                                @((item.Price * item.Quantity).ToString("F2")) $
                            </div>

                            <form method="post" action="/Home/RemoveFromCart" style="margin:0;flex-shrink:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />

                                <button type="submit" class="btn btn-danger" style="padding:8px 10px;" title="Remove item">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    }

                    <a href="/Home/Products" class="btn btn-secondary" style="text-decoration:none;margin-top:.5rem;">
                        <i class="fas fa-plus"></i> Add More
                    </a>
                </div>

                <div class="summary-card">
                    <h3 style="margin-bottom:1rem;font-size:1rem;font-weight:700;">
                        Order Summary
                    </h3>

                    @foreach (var item in Model)
                    {
                        <div class="summary-row">
                            <span style="color:var(--text-muted);">
                                @item.CategoryIcon @item.ProductName × @item.Quantity
                            </span>
                            <span>
                                @((item.Price * item.Quantity).ToString("F2")) $
                            </span>
                        </div>
                    }

                    <div class="summary-row" style="margin-top:.4rem;">
                        <span>Shipping</span>
                        <span style="color:var(--success);">Free 🎉</span>
                    </div>

                    <div class="summary-row">
                        <span class="summary-total">Total</span>
                        <span class="summary-total">@total.ToString("F2") $</span>
                    </div>

                    <form method="post" action="/Home/Checkout" style="margin-top:1rem;">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-success" style="width:100%;justify-content:center;font-size:1rem;padding:13px;">
                            <i class="fas fa-credit-card"></i> Checkout
                        </button>
                    </form>

                    <div style="text-align:center;margin-top:.8rem;">
                        <i class="fas fa-lock" style="color:var(--text-muted);font-size:.75rem;"></i>
                        <span style="color:var(--text-muted);font-size:.75rem;">
                            Secure & encrypted payment simulation
                        </span>
                    </div>

                    <div style="display:flex;justify-content:center;gap:.5rem;margin-top:.7rem;font-size:1.3rem;">
                        💳 🏦 📱
                    </div>
                </div>
            </div>
        }
