@model List<RecommendationApp.Models.Product>
@using RecommendationApp.Services
@{
    ViewData["Title"] = "Browse Products";
    ViewData["ActivePage"] = "Products";
    var categories = ViewBag.Categories as List<string?> ?? new List<string?>();
    var selectedCat = ViewBag.SelectedCategory as string;
}

@section Styles {
<style>
    .filter-bar { display:flex; gap:.7rem; align-items:center; flex-wrap:wrap; margin-bottom:1.2rem; padding:.9rem 1rem; background:var(--surface); border:1px solid var(--border); border-radius:14px; }
    .search-box { flex:1; min-width:160px; display:flex; align-items:center; gap:8px; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:8px 12px; }
    .search-box input { flex:1; border:none; background:transparent; color:var(--text); font-family:'Segoe UI', Tahoma, sans-serif; font-size:.88rem; outline:none; min-width:0; }
    .search-box input::placeholder { color:var(--text-muted); }
    .filter-select { padding:8px 12px; background:var(--bg); border:1px solid var(--border); border-radius:10px; color:var(--text); font-family:'Segoe UI', Tahoma, sans-serif; font-size:.85rem; cursor:pointer; outline:none; }
    .filter-select:focus { border-color:var(--accent); }

    @@media(max-width:480px) {
        .search-box { width:100%; }
        .filter-select { flex:1; }
    }

    .cat-pills { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.2rem; }
    .cat-pill { padding:5px 13px; border-radius:50px; border:1px solid var(--border); background:var(--surface); color:var(--text-muted); font-size:.78rem; font-weight:600; cursor:pointer; text-decoration:none; transition:all .2s; }
    .cat-pill:hover,
    .cat-pill.active { border-color:var(--accent); color:var(--accent); background:rgba(0,212,255,.05); }

    .product-icon-area { width:100%; height:150px; display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; gap:5px; }
    .icon-emoji { font-size:3.5rem; line-height:1; }
    .product-category-badge { position:absolute; top:8px; right:8px; font-size:.65rem; padding:3px 9px; border-radius:50px; font-weight:700; border:1px solid; }
    .product-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; overflow:hidden; transition:all .3s; }
    .product-card:hover { transform:translateY(-4px); border-color:rgba(0,212,255,.3); box-shadow:0 15px 35px rgba(0,0,0,.3); }
    .product-body { padding:.9rem; }
    .product-name { font-size:.88rem; font-weight:700; margin-bottom:5px; }
    .product-price { font-size:1.05rem; font-weight:900; color:var(--accent3); margin-bottom:8px; }
    .product-actions { display:flex; gap:7px; }
    .product-actions .btn { flex:1; justify-content:center; font-size:.78rem; padding:7px 10px; }

    .products-grid { display:grid; gap:1rem; grid-template-columns:repeat(2,1fr); }

    @@media(min-width:640px) {
        .products-grid { grid-template-columns:repeat(3,1fr); }
    }

    @@media(min-width:900px) {
        .products-grid { grid-template-columns:repeat(4,1fr); }
    }

    @@media(min-width:1200px) {
        .products-grid { grid-template-columns:repeat(5,1fr); }
    }
</style>
}

<div class="section-header">
    <i class="fas fa-store" style="color:var(--accent)"></i>
    <h2>Browse Products</h2>
    <span class="section-badge">@Model.Count product@(Model.Count == 1 ? "" : "s")</span>
    <div class="divider"></div>
</div>

<form method="get" action="/Home/Products">
    <div class="filter-bar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input
                type="text"
                name="search"
                value="@ViewBag.Search"
                placeholder="Search by category..." />
        </div>

        <select name="category" class="filter-select" onchange="this.form.submit()">
            <option value="">All Categories</option>

            @foreach (var cat in categories.Where(c => c != null))
            {
                if (cat == selectedCat)
                {
                    <option value="@cat" selected="selected">@cat</option>
                }
                else
                {
                    <option value="@cat">@cat</option>
                }
            }
        </select>

        <input
            type="number"
            name="minPrice"
            class="filter-select"
            placeholder="Min $"
            style="width:90px;" />

        <input
            type="number"
            name="maxPrice"
            class="filter-select"
            placeholder="Max $"
            style="width:90px;" />

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-filter"></i> Filter
        </button>

        <a href="/Home/Products" class="btn btn-secondary" title="Reset filters">
            <i class="fas fa-times"></i>
        </a>
    </div>
</form>

<div class="cat-pills">
    <a href="/Home/Products" class="cat-pill @(selectedCat == null ? "active" : "")">
        🛍️ All
    </a>

    @foreach (var cat in categories.Where(c => c != null))
    {
        <a href="/Home/Products?category=@Uri.EscapeDataString(cat!)"
           class="cat-pill @(cat == selectedCat ? "active" : "")">
            @CategoryHelper.GetIcon(cat) @cat
        </a>
    }
</div>

<p style="color:var(--text-muted);font-size:.85rem;margin-bottom:1rem;">
    Showing
    <span style="color:var(--accent);font-weight:700;">@Model.Count</span>
    product@(Model.Count == 1 ? "" : "s")
</p>

@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:3rem;">
        <div style="font-size:3rem;margin-bottom:1rem;">🔍</div>

        <p style="color:var(--text-muted);">
            No products match your search.
        </p>

        <a href="/Home/Products" class="btn btn-secondary" style="margin-top:1rem;text-decoration:none;">
            Reset
        </a>
    </div>
}
else
{
    <div class="products-grid">
        @foreach (var product in Model)
        {
            var color = CategoryHelper.GetColor(product.Category);
            var icon = CategoryHelper.GetIcon(product.Category);

            <div class="product-card">
                <div class="product-icon-area" style="background:linear-gradient(135deg,@(color)18,@(color)30);">
                    <div class="icon-emoji">@icon</div>

                    <span class="product-category-badge"
                          style="background:@(color)20;border-color:@(color)55;color:@color;">
                        @(product.Category ?? "—")
                    </span>
                </div>

                <div class="product-body">
                    <div class="product-name">
                        Product #@product.ProductId
                    </div>

                    <div class="product-price">
                        @(product.Price?.ToString("F0") ?? "0") $
                    </div>

                    <div class="product-actions">
                        <a href="/Home/ProductDetail/@product.ProductId"
                           class="btn btn-secondary"
                           style="text-decoration:none;flex:0 0 auto;padding:7px 10px;"
                           title="View product">
                            <i class="fas fa-eye"></i>
                        </a>

                        <button class="btn btn-primary" onclick="addToCart(@product.ProductId,this)" type="button">
                            <i class="fas fa-cart-plus"></i> Add
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}


