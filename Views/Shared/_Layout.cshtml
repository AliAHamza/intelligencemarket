<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>@ViewData["Title"] - Intelligence Market</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        :root {
            --bg:#0a0e1a; --surface:#111827; --surface2:#1a2235;
            --border:#1e2d45; --accent:#00d4ff; --accent2:#7c3aed;
            --accent3:#f59e0b; --text:#e2e8f0; --text-muted:#64748b;
            --success:#10b981; --danger:#ef4444;
            --nav-bg:rgba(10,14,26,0.95);
            --grid-color:rgba(0,212,255,0.03);
            --card-glow:0 0 30px rgba(0,212,255,0.08);
            --nav-h:64px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }

        body {
            font-family:'Segoe UI', Tahoma, sans-serif;
            background:var(--bg);
            color:var(--text);
            min-height:100vh;
            overflow-x:hidden;
            transition:background .3s,color .3s;
        }

        body::before {
            content:'';
            position:fixed;
            inset:0;
            background-image:
                linear-gradient(var(--grid-color) 1px,transparent 1px),
                linear-gradient(90deg,var(--grid-color) 1px,transparent 1px);
            background-size:50px 50px;
            pointer-events:none;
            z-index:0;
        }

        body.light-mode { background:var(--bg); }
        body.light-mode .card { box-shadow:0 2px 12px rgba(0,0,0,0.08); }
        body.light-mode .product-card:hover { box-shadow:0 15px 35px rgba(0,0,0,0.12); }

        .navbar {
            position:sticky;
            top:0;
            z-index:1000;
            background:var(--nav-bg);
            backdrop-filter:blur(20px);
            border-bottom:1px solid var(--border);
            height:var(--nav-h);
            padding:0 1.5rem;
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:1rem;
            transition:background .3s,border-color .3s;
        }

        .navbar-brand {
            display:flex;
            align-items:center;
            gap:8px;
            text-decoration:none;
            font-size:1.15rem;
            font-weight:900;
            color:var(--accent);
            flex-shrink:0;
        }

        .navbar-brand .logo-icon {
            width:34px;
            height:34px;
            border-radius:9px;
            flex-shrink:0;
            background:linear-gradient(135deg,var(--accent),var(--accent2));
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:.9rem;
        }

        .navbar-brand span { color:var(--text); }

        .nav-links {
            display:flex;
            align-items:center;
            gap:.3rem;
            list-style:none;
        }

        .nav-links a {
            display:flex;
            align-items:center;
            gap:6px;
            padding:7px 13px;
            border-radius:10px;
            text-decoration:none;
            color:var(--text-muted);
            font-size:.87rem;
            font-weight:600;
            transition:all .2s;
            white-space:nowrap;
        }

        .nav-links a:hover,
        .nav-links a.active {
            background:var(--surface2);
            color:var(--accent);
        }

        .cart-badge {
            background:var(--accent);
            color:var(--bg);
            font-size:.6rem;
            font-weight:900;
            border-radius:50%;
            width:17px;
            height:17px;
            display:inline-flex;
            align-items:center;
            justify-content:center;
        }

        .nav-right {
            display:flex;
            align-items:center;
            gap:8px;
        }

        .user-pill {
            display:flex;
            align-items:center;
            gap:6px;
            background:var(--surface2);
            border:1px solid var(--border);
            border-radius:50px;
            padding:5px 12px;
            font-size:.82rem;
            color:var(--accent);
            font-weight:700;
            white-space:nowrap;
        }

        .btn-logout {
            padding:7px 13px;
            border-radius:10px;
            border:1px solid var(--border);
            background:transparent;
            color:var(--text-muted);
            font-family:'Segoe UI', Tahoma, sans-serif;
            font-size:.82rem;
            cursor:pointer;
            transition:all .2s;
            display:flex;
            align-items:center;
            gap:5px;
            white-space:nowrap;
        }

        .btn-logout:hover {
            border-color:var(--danger);
            color:var(--danger);
        }

        .icon-btn {
            width:36px;
            height:36px;
            border-radius:10px;
            border:1px solid var(--border);
            background:var(--surface2);
            color:var(--text);
            font-size:.95rem;
            cursor:pointer;
            display:flex;
            align-items:center;
            justify-content:center;
            transition:all .2s;
            font-family:'Segoe UI', Tahoma, sans-serif;
            font-weight:700;
            flex-shrink:0;
        }

        .icon-btn:hover {
            border-color:var(--accent);
            color:var(--accent);
            transform:scale(1.05);
        }

        .hamburger {
            display:none;
            flex-direction:column;
            gap:5px;
            cursor:pointer;
            background:none;
            border:none;
            padding:7px;
            border-radius:8px;
        }

        .hamburger span {
            display:block;
            width:22px;
            height:2px;
            background:var(--text);
            border-radius:2px;
            transition:all .3s;
        }

        .hamburger.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
        .hamburger.open span:nth-child(2) { opacity:0; }
        .hamburger.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }

        .mobile-menu {
            display:none;
            position:fixed;
            top:var(--nav-h);
            right:0;
            left:0;
            background:var(--nav-bg);
            backdrop-filter:blur(20px);
            border-bottom:1px solid var(--border);
            padding:1rem 1.2rem 1.5rem;
            z-index:999;
            flex-direction:column;
            gap:.35rem;
        }

        @@keyframes slideDown {
            from { opacity:0; transform:translateY(-8px); }
            to { opacity:1; transform:translateY(0); }
        }

        .mobile-menu.open {
            display:flex;
            animation:slideDown .2s ease;
        }

        .mobile-menu a {
            display:flex;
            align-items:center;
            gap:10px;
            padding:12px 16px;
            border-radius:12px;
            text-decoration:none;
            color:var(--text-muted);
            font-size:.97rem;
            font-weight:600;
            transition:all .2s;
            border:1px solid transparent;
        }

        .mobile-menu a:hover,
        .mobile-menu a.active {
            background:var(--surface2);
            border-color:var(--border);
            color:var(--accent);
        }

        .mobile-divider {
            height:1px;
            background:var(--border);
            margin:.4rem 0;
        }

        .mobile-user-row {
            display:flex;
            align-items:center;
            justify-content:space-between;
            padding:10px 16px;
            background:var(--surface2);
            border-radius:12px;
            margin-bottom:.3rem;
        }

        .mobile-user-row span {
            color:var(--accent);
            font-weight:700;
            font-size:.9rem;
        }

        .mobile-bottom-row {
            display:flex;
            gap:.5rem;
        }

        .mobile-logout-btn {
            flex:1;
            padding:12px;
            border-radius:12px;
            border:1px solid var(--border);
            background:transparent;
            color:var(--danger);
            font-family:'Segoe UI', Tahoma, sans-serif;
            font-size:.9rem;
            font-weight:700;
            cursor:pointer;
            display:flex;
            align-items:center;
            justify-content:center;
            gap:8px;
            transition:all .2s;
        }

        .mobile-logout-btn:hover {
            background:rgba(239,68,68,.1);
        }

        .mobile-icon-btn {
            flex:0 0 auto;
            padding:12px;
            border-radius:12px;
            border:1px solid var(--border);
            background:var(--surface2);
            color:var(--text);
            font-family:'Segoe UI', Tahoma, sans-serif;
            font-size:.9rem;
            font-weight:700;
            cursor:pointer;
            transition:all .2s;
        }

        main {
            position:relative;
            z-index:1;
            max-width:1400px;
            margin:0 auto;
            padding:1.5rem 1rem;
        }

        @@media(min-width:768px) {
            main { padding:2rem 1.5rem; }
        }

        .card {
            background:var(--surface);
            border:1px solid var(--border);
            border-radius:16px;
            padding:1.5rem;
            box-shadow:var(--card-glow);
            transition:border-color .2s,background .3s;
        }

        .card:hover {
            border-color:rgba(0,212,255,.2);
        }

        .btn {
            display:inline-flex;
            align-items:center;
            gap:7px;
            padding:10px 18px;
            border-radius:10px;
            font-family:'Segoe UI', Tahoma, sans-serif;
            font-weight:700;
            font-size:.88rem;
            cursor:pointer;
            border:none;
            text-decoration:none;
            transition:all .2s;
        }

        .btn-primary {
            background:linear-gradient(135deg,var(--accent),#0099cc);
            color:var(--bg);
        }

        .btn-primary:hover {
            transform:translateY(-2px);
            box-shadow:0 8px 25px rgba(0,212,255,.3);
        }

        .btn-secondary {
            background:var(--surface2);
            color:var(--text);
            border:1px solid var(--border);
        }

        .btn-secondary:hover {
            border-color:var(--accent);
            color:var(--accent);
        }

        .btn-success {
            background:linear-gradient(135deg,var(--success),#059669);
            color:#fff;
        }

        .btn-success:hover {
            transform:translateY(-2px);
            box-shadow:0 8px 25px rgba(16,185,129,.3);
        }

        .btn-danger {
            background:rgba(239,68,68,.1);
            color:var(--danger);
            border:1px solid rgba(239,68,68,.2);
        }

        .btn-danger:hover {
            background:var(--danger);
            color:#fff;
        }

        .product-card {
            background:var(--surface);
            border:1px solid var(--border);
            border-radius:16px;
            overflow:hidden;
            transition:all .3s;
        }

        .product-card:hover {
            transform:translateY(-4px);
            border-color:rgba(0,212,255,.3);
            box-shadow:0 20px 40px rgba(0,0,0,.3),var(--card-glow);
        }

        .products-grid {
            display:grid;
            gap:1rem;
            grid-template-columns:repeat(2,1fr);
        }

        @@media(min-width:640px) {
            .products-grid { grid-template-columns:repeat(3,1fr); }
        }

        @@media(min-width:900px) {
            .products-grid {
                grid-template-columns:repeat(4,1fr);
                gap:1.2rem;
            }
        }

        @@media(min-width:1200px) {
            .products-grid { grid-template-columns:repeat(5,1fr); }
        }

        .section-header {
            display:flex;
            align-items:center;
            gap:10px;
            margin-bottom:1.2rem;
            flex-wrap:wrap;
        }

        .section-header h2 {
            font-size:1.15rem;
            font-weight:900;
            color:var(--text);
        }

        @@media(min-width:768px) {
            .section-header h2 { font-size:1.3rem; }
        }

        .section-badge {
            background:linear-gradient(135deg,var(--accent),var(--accent2));
            color:#fff;
            font-size:.68rem;
            padding:3px 10px;
            border-radius:50px;
            font-weight:700;
            white-space:nowrap;
        }

        .divider {
            flex:1;
            height:1px;
            background:linear-gradient(90deg,var(--border),transparent);
            min-width:20px;
        }

        #toast {
            position:fixed;
            bottom:1.5rem;
            left:50%;
            transform:translateX(-50%) translateY(100px);
            background:var(--surface);
            border:1px solid var(--accent);
            color:var(--text);
            padding:10px 22px;
            border-radius:50px;
            font-size:.88rem;
            font-weight:600;
            z-index:9999;
            transition:transform .3s;
            white-space:nowrap;
            box-shadow:0 10px 40px rgba(0,0,0,.4);
            max-width:90vw;
            text-align:center;
        }

        #toast.show {
            transform:translateX(-50%) translateY(0);
        }

        @@media(max-width:767px) {
            .nav-links,
            .nav-right { display:none; }

            .hamburger { display:flex; }

            .card { padding:1rem; }
        }

        @@media(min-width:768px) {
            .hamburger,
            .mobile-menu { display:none !important; }
        }

        ::-webkit-scrollbar { width:5px; }
        ::-webkit-scrollbar-track { background:var(--bg); }
        ::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }
        ::-webkit-scrollbar-thumb:hover { background:var(--accent); }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    @if (Context.Session.GetInt32("UserId") != null)
    {
        var userId = Context.Session.GetInt32("UserId");
        var activePage = ViewData["ActivePage"]?.ToString() ?? "";

        <nav class="navbar">
            <a href="/Home/Index" class="navbar-brand">
                <div class="logo-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <span>Intelligence Market</span>
            </a>

            <ul class="nav-links">
                <li>
                    <a href="/Home/Index" class="@(activePage == "Dashboard" ? "active" : "")">
                        <i class="fas fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li>
                    <a href="/Home/Products" class="@(activePage == "Products" ? "active" : "")">
                        <i class="fas fa-store"></i>
                        <span>Products</span>
                    </a>
                </li>

                <li>
                    <a href="/Home/Cart" class="@(activePage == "Cart" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Cart</span>
                        <span class="cart-badge" id="cartCount">0</span>
                    </a>
                </li>
            </ul>

            <div class="nav-right">
                <button class="icon-btn" id="themeToggle" onclick="Theme.toggle()" title="Toggle theme">
                    🌙
                </button>

                <div class="user-pill">
                    <i class="fas fa-user-circle"></i>
                    <span>User #@userId</span>
                </div>

                <form action="/Account/Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>

            <button class="hamburger" id="hamburger" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>

        <div class="mobile-menu" id="mobileMenu">
            <div class="mobile-user-row">
                <span>
                    <i class="fas fa-user-circle"></i>
                    User #@userId
                </span>

                <span class="cart-badge" id="cartCountMobile" style="width:22px;height:22px;font-size:.75rem;">
                    0
                </span>
            </div>

            <a href="/Home/Index" class="@(activePage == "Dashboard" ? "active" : "")">
                <i class="fas fa-chart-pie"></i>
                <span>Dashboard</span>
            </a>

            <a href="/Home/Products" class="@(activePage == "Products" ? "active" : "")">
                <i class="fas fa-store"></i>
                <span>Products</span>
            </a>

            <a href="/Home/Cart" class="@(activePage == "Cart" ? "active" : "")">
                <i class="fas fa-shopping-cart"></i>
                <span>Cart</span>
            </a>

            <div class="mobile-divider"></div>

            <div class="mobile-bottom-row">
                <button
                    class="mobile-icon-btn"
                    id="themeToggleMobile"
                    onclick="Theme.toggle();document.getElementById('mobileMenu').classList.remove('open');document.getElementById('hamburger').classList.remove('open')">
                    🌙
                </button>

                <form action="/Account/Logout" method="post" style="flex:1;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="mobile-logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Sign Out</span>
                    </button>
                </form>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <div id="toast"></div>

    <script src="/js/theme.js"></script>

    <script>
        Theme.init();

        function syncMobileToggles() {
            const themeToggleMobile = document.getElementById('themeToggleMobile');

            if (themeToggleMobile) {
                themeToggleMobile.textContent = Theme.current === 'dark' ? '☀️' : '🌙';
            }
        }

        const originalThemeToggle = Theme.toggle.bind(Theme);

        Theme.toggle = function () {
            originalThemeToggle();
            syncMobileToggles();
        };

        syncMobileToggles();

        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobileMenu');

        if (hamburger && mobileMenu) {
            hamburger.addEventListener('click', () => {
                hamburger.classList.toggle('open');
                mobileMenu.classList.toggle('open');
            });

            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    hamburger.classList.remove('open');
                    mobileMenu.classList.remove('open');
                });
            });
        }

        function showToast(message, color = '#00d4ff') {
            const toast = document.getElementById('toast');

            toast.textContent = message;
            toast.style.borderColor = color;
            toast.classList.add('show');

            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        async function addToCart(productId, button) {
            if (button) {
                button.disabled = true;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }

            try {
                const formData = new FormData();

                formData.append('productId', productId);
                formData.append(
                    '__RequestVerificationToken',
                    document.querySelector('input[name=__RequestVerificationToken]')?.value || ''
                );

                const response = await fetch('/Home/AddToCart', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    ['cartCount', 'cartCountMobile'].forEach(id => {
                        const element = document.getElementById(id);

                        if (element) {
                            element.textContent = data.count;
                        }
                    });

                    showToast('✓ Added to cart!');

                    if (button) {
                        button.innerHTML = '<i class="fas fa-check"></i> Added';
                        button.style.background = '#10b981';
                    }
                } else if (button) {
                    button.disabled = false;
                    button.innerHTML = '<i class="fas fa-cart-plus"></i> Add';
                }
            } catch {
                if (button) {
                    button.disabled = false;
                    button.innerHTML = '<i class="fas fa-cart-plus"></i> Add';
                }
            }
        }

        fetch('/Home/GetCartCount')
            .then(response => response.json())
            .then(data => {
                ['cartCount', 'cartCountMobile'].forEach(id => {
                    const element = document.getElementById(id);

                    if (element) {
                        element.textContent = data.count;
                    }
                });
            })
            .catch(() => {});
    </script>

    @Html.AntiForgeryToken()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>